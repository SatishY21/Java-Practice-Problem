import java.util.Scanner;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String str = sc.nextLine();
        int blank = 0,ch = 0;
        for(int i = 0; i<str.length(); i++){
            if(str.charAt(i) == ' '){
                blank++;
            }else{
                ch++;
            }
        }
        
        System.out.println(blank +" "+ ch);
    }
}
